  "git.confirmSync": false,
  "python.terminal.activateEnvInCurrentTerminal": true,
  "latex-workshop.view.pdf.viewer": "tab",
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "python.languageServer": "Pylance",
  "python.testing.promptToConfigure": false,
  "python.testing.autoTestDiscoverOnSaveEnabled": false,
  "editor.renderWhitespace": "all",
  "editor.renderControlCharacters": true,
  "editor.wordWrap": "on",
  "latex-workshop.latex.recipe.default": "lastUsed",
  "jupyter.askForKernelRestart": false,
  "terminal.integrated.inheritEnv": false,
  "files.watcherExclude": {
    "env/**": true
  },
  "remote.SSH.connectTimeout": 20,
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook",
    "*.h5": "h5web.fallback-viewer",
    "file:/**/*.csv": "jupyter-data-wrangler",
    "*.csv": "default"
  },
  "remote.SSH.enableX11Forwarding": false,
  "remote.SSH.showLoginTerminal": true,
  "ltex.disabledRules": {
    "en-GB": [
      "PASSIVE_VOICE"
    ]
  },
  "security.workspace.trust.untrustedFiles": "open",
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "git.suggestSmartCommit": false,
  "[rust]": {},
  "python.analysis.diagnosticSeverityOverrides": {
    "reportPrivateImportUsage": "none"
  },
  "githubPullRequests.createOnPublishBranch": "never",
  "editor.lineNumbers": "on",
  "editor.glyphMargin": true,
  "editor.minimap.enabled": true,
  "files.associations": {
    ".coveragerc": "plaintext"
  },
  "githubPullRequests.pullBranch": "never",
  "[python]": {
    "editor.formatOnType": true,
    "editor.defaultFormatter": "ms-python.autopep8",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "latex-workshop.bibtex-format.sort.enabled": true,
  "latex-workshop.latex.autoBuild.run": "onSave",
  "zenMode.hideLineNumbers": false,
  "git.openRepositoryInParentFolders": "never",
  "notebook.lineNumbers": "on",
  "jupyter.interactiveWindow.textEditor.executeSelection": true,
  "lldb.suppressUpdateNotifications": true,
  "notebook.formatOnSave.enabled": true,
  "window.commandCenter": true,
  "pylint.args": [
    "--max-line-length=89"
  ],
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.defaultFormatter": "ms-python.black-formatter",
  "dataWrangler.columnInsights.displayOnOpen": false,
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "editor.fontLigatures": true,
  "workbench.preferredHighContrastColorTheme": "Dark Modern",
  "workbench.preferredHighContrastLightColorTheme": "Atom One Light",
  "dataWrangler.experiments.copilot.enabled": false,
  "dataWrangler.panels.displayOnTabFocus": false,
  "debug.onTaskErrors": "abort",
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  // these settings are 'false' by default, so removing those should also work
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "python.analysis.autoFormatStrings": true,
  // to make neovim not crash
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 5,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "before": [
        "j",
        "j"
      ],
      "after": [
        "<Esc>"
      ]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<leader>",
        "d"
      ],
      "after": [
        "d",
        "d"
      ]
    },
    {
      "before": [
        "<C-n>"
      ],
      "commands": [
        ":nohl"
      ]
    },
    {
      "before": [
        "K"
      ],
      "commands": [
        "lineBreakInsert"
      ],
      "silent": true
    },
    {
      "before": [
        "J"
      ],
      "after": [
        "m",
        "z",
        "J",
        "`",
        "z"
      ],
      "silent": true
    },
    {
      "before": [
        "<C-u>"
      ],
      "after": [
        "<C-u>",
        "z",
        "z",
      ],
      "silent": true
    },
    {
      "before": [
        "<C-d>"
      ],
      "after": [
        "<C-d>",
        "z",
        "z",
      ],
      "silent": true
    },
    {
      "before": [
        "<leader>",
        "m"
      ],
      "commands": [
        "bookmarks.toggle"
      ]
    },
    {
      "before": [
        "<leader>",
        "b",
      ],
      "commands": [
        "bookmarks.listFromAllFiles"
      ]
    },
    {
      "before": [
        "<C-s>",
      ],
      "commands": [
        "workbench.action.files.save",
      ]
    },
    {
      "before": [
        "leader",
        "/"
      ],
      "commands": [
        "editor.action.commentLine",
      ]
    },
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": [
        "leader",
        "/"
      ],
      "commands": [
        "editor.action.commentLine",
      ]
    },
    {
      "before": [
        ">"
      ],
      "commands": [
        "editor.action.indentLines"
      ]
    },
    {
      "before": [
        "<"
      ],
      "commands": [
        "editor.action.outdentLines"
      ]
    },
  ],
  "vim.leader": "<space>",
  "vim.handleKeys": {
    "<C-s>": true,
    "<C-a>": false,
    "<C-f>": false
  },
  // To improve performance,
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },
  "vim.sneak": true,
  "vim.sneakReplacesF": true,
  "vim.easymotionDimBackground": false,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.selectedCompletionModel": "",
  "search.exclude": {
    "data/**": true
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "workbench.preferredLightColorTheme": "Atom One Light",
  "workbench.preferredDarkColorTheme": "Atom One Dark",
  "github.copilot.chat.notebook.enhancedNextEditSuggestions.enabled": true,
  "jupyter.debugJustMyCode": false,
  "debugpy.debugJustMyCode": false,
  "workbench.colorTheme": "Atom One Dark",
  "editor.inlineSuggest.edits.allowCodeShifting": "never",
  "python.analysis.exclude": [
    "**/data",
    "**/.venv"
  ]
}